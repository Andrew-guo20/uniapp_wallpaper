// 用户收藏表
{
	"bsonType": "object",
	"required": ["wallId", "uid"],
	"permission": {
		"read": true,
		"create": "auth.uid != null",
		"update": false,
		"delete": "doc.uid == auth.uid"
	},
	"properties": {
		"_id": { "description": "系统自动生成" },
		"wallId": { "bsonType": "string", "description": "壁纸ID" },
		"uid": { "bsonType": "string", "description": "用户uid" },
		"create_time": { "bsonType": "timestamp", "description": "收藏时间" }
	},
	"index": [
		{ "name": "unique_wall_user", "unique": true, "fieldList": { "wallId": 1, "uid": 1 } },
		{ "name": "idx_uid_time", "fieldList": { "uid": 1, "create_time": -1 } }
	]
}
