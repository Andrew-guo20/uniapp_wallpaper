// 用户评分记录
{
	"bsonType": "object",
	"required": ["wallId", "deviceId", "userScore"],
	"permission": {
		"read": true,
		"create": true,
		"update": false,
		"delete": false
	},
	"properties": {
		"_id": {
			"description": "系统自动生成"
		},
		"wallId": {
			"bsonType": "string",
			"description": "壁纸ID，关联wallpaper-list._id"
		},
		"deviceId": {
			"bsonType": "string",
			"description": "设备ID（暂代用户标识，后续迁移到openid）"
		},
		"userScore": {
			"bsonType": "double",
			"description": "用户评分(0-5)"
		},
		"create_time": {
			"bsonType": "timestamp",
			"description": "评分时间"
		}
	},
	"index": [{
		"name": "unique_wall_device",
		"unique": true,
		"fieldList": {
			"wallId": 1,
			"deviceId": 1
		}
	}]
}
